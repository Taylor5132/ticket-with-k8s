# Your public domain name (e.g. ticket.yourdomain.com)
# Caddy uses this to obtain a Let's Encrypt HTTPS certificate automatically.
DOMAIN=limseong

# Cloudflare Tunnel token — from Zero Trust > Networks > Tunnels > your tunnel > Configure
# Only needed when running: docker compose --profile tunnel up
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here

# Set to "true" to enable real Google OAuth (requires GOOGLE_CLIENT_ID/SECRET above).
# When "false" (default), the Google button uses dev-login (demo-rich, 300K points).
GOOGLE_OAUTH_ENABLED=false

# Google OAuth credentials
# Get these from https://console.cloud.google.com/ > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Must match the Authorized redirect URI registered in Google Cloud Console
GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/google/callback
FRONTEND_URL=https://your-domain.com
